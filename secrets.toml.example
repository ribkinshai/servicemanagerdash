# העתיקי את הקובץ הזה ל-.streamlit/secrets.toml ומלאי את הפרטים.
# הקובץ secrets.toml אסור להעלות ל-GitHub (כבר ב-.gitignore).

# ===== חובה: גישה ל-GitHub לאחסון המשימות =====
[github]
# Personal Access Token עם הרשאת 'repo'
# יצירה: https://github.com/settings/tokens
token = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
repo = "your-username/task-manager-data"
file_path = "data/tasks.json"  # אופציונלי
branch = "main"                 # אופציונלי

# ===== להוספה חכמה עם Claude =====
# הירשמי ב-https://console.anthropic.com וצרי API key
[anthropic]
api_key = "sk-ant-xxxxxxxxxxxxxxxxxxxx"

# ===== לסנכרון Outlook (לאחר קבלת פרטים מ-IT) =====
# [outlook]
# tenant_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# client_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# client_secret = "xxxxxxxxxxxxxxxxxxxxxxxxx"
